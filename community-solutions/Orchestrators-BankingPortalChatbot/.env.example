# ──────────────────────────────────────────────────────────────────────
# Banking Portal Chatbot — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────────────

# Protegrity Developer Edition credentials
# Sign up at: https://www.protegrity.com/developers/dev-edition-api
DEV_EDITION_EMAIL=your-email@company.com
DEV_EDITION_PASSWORD=your-password
DEV_EDITION_API_KEY=your-api-key

# Protegrity policy user (default role for detokenization)
PROTEGRITY_POLICY_USER=superuser

# Protegrity service endpoints (defaults — change if containers run elsewhere)
CLASSIFY_URL=http://localhost:8580/pty/data-discovery/v1.1/classify
SGR_URL=http://localhost:8581/pty/semantic-guardrail/v1.1/conversations/messages/scan

# Protegrity REST API for user-based detokenization (Gate 2)
PROTEGRITY_HOST=http://localhost:8580
DETOKENIZE_URL=http://localhost:8580/pty/data-discovery/v1.1/unprotect
PROTEGRITY_API_TIMEOUT=60

# Protegrity feature toggles (both enabled by default)
GUARDRAIL_ENABLED=true
DISCOVERY_ENABLED=true

# LLM API Keys (at least one required)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...

# LLM model override (optional — defaults are set in orchestration_config.py)
#OPENAI_MODEL=gpt-4o-mini

# ── PostgreSQL — Banking customer data ──────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=protegrity
DB_USER=protegrity
DB_PASSWORD=protegrity

# ── KùzuDB — embedded knowledge graph ───────────────────────────────
# Path to the KùzuDB file (Kuzu 0.11+ single-file format).
# Docker override: /app/kuzu_data/banking.kuzu (set in docker-compose.yml)
KUZU_DB_PATH=./kuzu_data/banking.kuzu
