# .dockerignore — exclude files that shouldn't be in the Docker image

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Protegrity setup artifacts (containers run separately)
.protegrity-install/

# Test artifacts
.pytest_cache/
.coverage
htmlcov/
tests/

# Git
.git/
.gitignore

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Secrets / credentials — DO NOT bake into image; pass via env_file at runtime
.env

# Chroma DB (mounted as a volume at runtime)
chroma_db/

# Generated databases (rebuilt at runtime)
kuzu_data/
kuzu_test_tmp

# Logs
*.log

# Chat histories (mounted as volumes at runtime)
TechnicalApp/chat_history_tech/
BusinessCustomerApp/chat_history/

# Readme-only files
readme/
README.md
